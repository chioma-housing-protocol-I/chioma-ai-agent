# App
NODE_ENV=development
PORT=3100

# LLM provider: "openai" | "anthropic"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Chioma backend API (see chioma/backend/openapi.json)
# Local development (running the backend directly on your machine):
CHIOMA_API_URL=http://localhost:3000
# Docker Compose (use the Compose service name instead of localhost):
# CHIOMA_API_URL=http://chioma-backend:3000
CHIOMA_API_TOKEN=

# Session/memory store: "memory" | "redis"
SESSION_STORE=memory
# Local development:
REDIS_URL=redis://localhost:6379
# Docker Compose (use the Compose service name instead of localhost):
# REDIS_URL=redis://redis:6379
SESSION_TTL_SECONDS=3600

# Max tokens of prior session history sent to the LLM per turn. Oldest turns
# are dropped first once this is exceeded; the current message, system
# prompt, and tool definitions are on top of this budget.
HISTORY_TOKEN_BUDGET=24000

# Stellar Horizon API (read-only)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
